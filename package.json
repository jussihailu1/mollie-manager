{
  "name": "mollie-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "prebuild": "node scripts/clean-next-dev-types.mjs",
    "start": "next start",
    "lint": "eslint",
    "db:apply": "node scripts/db-apply.mjs",
